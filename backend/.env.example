# ─────────────────────────────────────────────────────────────────────────────
# LifeReel AI – Environment Configuration
# Rename this file to .env and fill in your real values before running.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string.
MONGO_URI=mongodb+srv://<db_username>:<db_password>@cluster0.rdmqh9g.mongodb.net/?appName=Cluster0

# OpenAI API key – obtainable from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
